---
import BaseLayout from '../layouts/BaseLayout.astro';

const specs = [
  { label: 'CPU', value: 'Any modern x86/ARM', note: '', noteColor: '' },
  { label: 'RAM', value: '8 GB minimum', note: '', noteColor: '' },
  { label: 'GPU', value: 'Optional (CUDA/Metal)', note: '+10x speed boost', noteColor: 'var(--accent-green)' },
  { label: 'DISK', value: '2 GB + model size', note: '', noteColor: '' },
  { label: 'PYTHON', value: '3.11 or newer', note: '', noteColor: '' },
  { label: 'INTERNET', value: 'Only for install', note: 'then fully offline', noteColor: 'var(--accent-gold)' },
];

const modules = [
  { name: 'Voice', color: 'var(--accent-gold)', cmd: 'pip install homie-ai[voice]', size: '~2 GB' },
  { name: 'Email', color: 'var(--accent-green)', cmd: 'pip install homie-ai[email]', size: '~5 MB' },
  { name: 'Neural', color: 'var(--accent-blue)', cmd: 'pip install homie-ai[neural]', size: '~50 MB' },
  { name: 'Service', color: 'var(--accent-red)', cmd: 'pip install homie-ai[service]', size: '~2 MB' },
];
---

<BaseLayout
  title="Download — Hey Homie"
  description="Install Homie AI on Windows, Linux, or macOS. Fully local, privacy-first AI assistant."
  activePage="download"
>
  <section class="pt-12 pb-8 px-6 text-center">
    <p class="status-line">■ DEPLOYMENT READY — v0.2.0</p>
    <h1 class="page-title">SUIT UP</h1>
    <p class="page-subtitle">SELECT YOUR PLATFORM • INSTALL • LAUNCH</p>
  </section>

  <div class="hud-divider"></div>

  <!-- Windows MSI Installer -->
  <section class="py-10 px-6 text-center max-w-2xl mx-auto" id="windows-installer">
    <p class="section-label" style="color: var(--accent-gold);">WINDOWS INSTALLER</p>
    <div style="border: 2px solid var(--border-gold); padding: 24px; background: var(--bg-card);">
      <div style="font-size: 32px; margin-bottom: 12px;">⊞</div>
      <div style="font-family: var(--font-pixel); font-size: 12px; color: var(--accent-gold); letter-spacing: 3px; margin-bottom: 8px;">WINDOWS 10/11</div>
      <p style="font-family: var(--font-retro); font-size: 15px; color: var(--text-body); margin-bottom: 16px; line-height: 1.6;">
        One-click MSI installer. Includes CLI, background service, system tray, and toast notifications. No Python required.
      </p>
      <a href="https://github.com/MSG-88/Homie/releases/latest/download/HomieSetup.msi"
         style="display: inline-block; font-family: var(--font-pixel); font-size: 14px; color: #000; background: var(--accent-gold); padding: 12px 32px; letter-spacing: 3px; text-decoration: none; border: none; cursor: pointer; margin-bottom: 12px;">
        DOWNLOAD MSI
      </a>
      <div style="font-family: var(--font-retro); font-size: 12px; color: var(--text-faint); margin-bottom: 16px;">
        v0.2.0 &bull; ~400 MB &bull; Includes all modules
      </div>
      <div style="display: flex; gap: 8px; justify-content: center; flex-wrap: wrap;">
        <div style="font-family: var(--font-retro); font-size: 13px; color: var(--text-faint); border: 1px solid var(--border-subtle); padding: 4px 10px;">CLI Console</div>
        <div style="font-family: var(--font-retro); font-size: 13px; color: var(--text-faint); border: 1px solid var(--border-subtle); padding: 4px 10px;">Background Daemon</div>
        <div style="font-family: var(--font-retro); font-size: 13px; color: var(--text-faint); border: 1px solid var(--border-subtle); padding: 4px 10px;">System Tray</div>
        <div style="font-family: var(--font-retro); font-size: 13px; color: var(--text-faint); border: 1px solid var(--border-subtle); padding: 4px 10px;">Toast Alerts</div>
      </div>
    </div>

    <!-- What the installer does -->
    <div style="border: 1px solid var(--border-subtle); padding: 18px; margin-top: 12px; text-align: left;">
      <div style="font-family: var(--font-pixel); font-size: 8px; color: var(--text-faint); letter-spacing: 2px; margin-bottom: 10px;">THE MSI INSTALLS</div>
      <div style="display: flex; flex-direction: column; gap: 8px;">
        <div style="display: flex; align-items: baseline; gap: 8px;">
          <span style="font-family: var(--font-pixel); font-size: 10px; color: var(--accent-green);">&#10003;</span>
          <div style="font-family: var(--font-retro); font-size: 13px; color: var(--text-body);">
            <span style="color: var(--accent-green);">homie.exe</span> and <span style="color: var(--accent-green);">homie-daemon.exe</span> to your system
          </div>
        </div>
        <div style="display: flex; align-items: baseline; gap: 8px;">
          <span style="font-family: var(--font-pixel); font-size: 10px; color: var(--accent-green);">&#10003;</span>
          <div style="font-family: var(--font-retro); font-size: 13px; color: var(--text-body);">
            Adds <span style="color: var(--accent-gold);">homie</span> to PATH — use from any terminal
          </div>
        </div>
        <div style="display: flex; align-items: baseline; gap: 8px;">
          <span style="font-family: var(--font-pixel); font-size: 10px; color: var(--accent-green);">&#10003;</span>
          <div style="font-family: var(--font-retro); font-size: 13px; color: var(--text-body);">
            Start Menu shortcuts for console and background daemon
          </div>
        </div>
        <div style="display: flex; align-items: baseline; gap: 8px;">
          <span style="font-family: var(--font-pixel); font-size: 10px; color: var(--accent-green);">&#10003;</span>
          <div style="font-family: var(--font-retro); font-size: 13px; color: var(--text-body);">
            Auto-starts daemon on login — runs silently in background
          </div>
        </div>
      </div>
    </div>

    <!-- pip alternative -->
    <div style="border: 1px solid var(--border-subtle); padding: 14px; margin-top: 12px; text-align: left;">
      <div style="font-family: var(--font-pixel); font-size: 8px; color: var(--text-faint); letter-spacing: 2px; margin-bottom: 8px;">DEVELOPER INSTALL (ALTERNATIVE)</div>
      <div style="background: #111; border: 1px solid var(--border-subtle); padding: 10px 14px; position: relative;">
        <div style="font-family: var(--font-retro); font-size: 14px; color: var(--accent-green);">
          <span style="color: var(--text-dim);">></span> pip install homie-ai[all]
        </div>
        <button
          class="copy-btn"
          data-cmd="pip install homie-ai[all]"
          style="position: absolute; top: 10px; right: 10px; font-family: var(--font-pixel); font-size: 8px; color: var(--text-faint); letter-spacing: 1px; border: 1px solid var(--text-ghost); padding: 2px 8px; background: none; cursor: pointer;"
        >COPY</button>
      </div>
      <div style="font-family: var(--font-retro); font-size: 12px; color: var(--text-faint); margin-top: 6px;">Requires Python 3.11+</div>
    </div>
  </section>

  <div class="hud-divider"></div>

  <!-- pip install (cross-platform) -->
  <section class="py-10 px-6 text-center max-w-2xl mx-auto">
    <p class="section-label" style="color: var(--accent-green);">CROSS-PLATFORM (PIP)</p>
    <div style="background: #111; border: 1px solid var(--border-subtle); padding: 16px 20px; text-align: left; position: relative;">
      <div style="font-family: var(--font-pixel); font-size: 8px; color: var(--text-faint); letter-spacing: 2px; margin-bottom: 8px;">TERMINAL</div>
      <div style="font-family: var(--font-retro); font-size: 18px; color: var(--accent-green);">
        <span style="color: var(--text-dim);">$</span> pip install homie-ai
      </div>
      <button
        class="copy-btn"
        data-cmd="pip install homie-ai"
        style="position: absolute; top: 16px; right: 16px; font-family: var(--font-pixel); font-size: 8px; color: var(--text-faint); letter-spacing: 1px; border: 1px solid var(--text-ghost); padding: 2px 8px; background: none; cursor: pointer;"
      >COPY</button>
    </div>
    <p style="font-family: var(--font-retro); font-size: 14px; color: var(--text-faint); margin-top: 10px; letter-spacing: 1px;">
      Core CLI — works on Windows, Linux, and macOS. Python 3.11+
    </p>
  </section>

  <div class="hud-divider"></div>

  <section class="py-10 px-6 max-w-2xl mx-auto">
    <p class="section-label" style="color: var(--accent-blue);">PLATFORM SELECT</p>
    <div class="grid grid-cols-3 gap-3">
      <div id="platform-windows" class="platform-card" style="border: 1px solid var(--border-subtle); padding: 20px 12px; text-align: center; cursor: pointer;" data-platform="windows">
        <div style="font-size: 22px; margin-bottom: 8px;">⊞</div>
        <div class="platform-name" style="font-family: var(--font-retro); font-size: 15px; color: var(--text-muted); letter-spacing: 2px;">WINDOWS</div>
        <div class="platform-detect" style="font-family: var(--font-pixel); font-size: 8px; color: var(--accent-green); margin-top: 6px; letter-spacing: 1px; visibility: hidden;">DETECTED ✓</div>
        <div style="font-family: var(--font-retro); font-size: 13px; color: var(--text-faint); margin-top: 8px;">Win 10/11</div>
        <div style="font-family: var(--font-pixel); font-size: 7px; color: var(--accent-gold); margin-top: 6px; letter-spacing: 1px;">DAEMON + TRAY</div>
      </div>
      <div id="platform-linux" class="platform-card" style="border: 1px solid var(--border-subtle); padding: 20px 12px; text-align: center; cursor: pointer;" data-platform="linux">
        <div style="font-size: 22px; margin-bottom: 8px;">🐧</div>
        <div class="platform-name" style="font-family: var(--font-retro); font-size: 15px; color: var(--text-muted); letter-spacing: 2px;">LINUX</div>
        <div class="platform-detect" style="font-family: var(--font-pixel); font-size: 8px; color: var(--accent-green); margin-top: 6px; letter-spacing: 1px; visibility: hidden;">DETECTED ✓</div>
        <div style="font-family: var(--font-retro); font-size: 13px; color: var(--text-faint); margin-top: 8px;">Ubuntu/Fedora/Arch</div>
      </div>
      <div id="platform-macos" class="platform-card" style="border: 1px solid var(--border-subtle); padding: 20px 12px; text-align: center; cursor: pointer;" data-platform="macos">
        <div style="font-size: 22px; margin-bottom: 8px;">🍎</div>
        <div class="platform-name" style="font-family: var(--font-retro); font-size: 15px; color: var(--text-muted); letter-spacing: 2px;">MACOS</div>
        <div class="platform-detect" style="font-family: var(--font-pixel); font-size: 8px; color: var(--accent-green); margin-top: 6px; letter-spacing: 1px; visibility: hidden;">DETECTED ✓</div>
        <div style="font-family: var(--font-retro); font-size: 13px; color: var(--text-faint); margin-top: 8px;">13+ (Ventura)</div>
      </div>
    </div>
  </section>

  <div class="hud-divider"></div>

  <!-- What's New in v0.2.0 -->
  <section class="py-10 px-6 max-w-2xl mx-auto">
    <p class="section-label" style="color: var(--accent-red);">NEW IN v0.2.0</p>
    <div class="flex flex-col gap-2">
      <div style="border: 1px solid var(--border-subtle); padding: 12px 14px; display: flex; align-items: center; gap: 12px;">
        <span style="font-family: var(--font-pixel); font-size: 10px; color: var(--accent-gold);">+</span>
        <div>
          <span style="font-family: var(--font-retro); font-size: 15px; color: var(--accent-gold);">Background Daemon</span>
          <span style="font-family: var(--font-retro); font-size: 13px; color: var(--text-faint); margin-left: 8px;">Runs silently, gathers intel, auto-restarts on crash</span>
        </div>
      </div>
      <div style="border: 1px solid var(--border-subtle); padding: 12px 14px; display: flex; align-items: center; gap: 12px;">
        <span style="font-family: var(--font-pixel); font-size: 10px; color: var(--accent-green);">+</span>
        <div>
          <span style="font-family: var(--font-retro); font-size: 15px; color: var(--accent-green);">Email Intelligence</span>
          <span style="font-family: var(--font-retro); font-size: 13px; color: var(--text-faint); margin-left: 8px;">LLM-powered triage, deadline detection, auto-draft replies</span>
        </div>
      </div>
      <div style="border: 1px solid var(--border-subtle); padding: 12px 14px; display: flex; align-items: center; gap: 12px;">
        <span style="font-family: var(--font-pixel); font-size: 10px; color: var(--accent-blue);">+</span>
        <div>
          <span style="font-family: var(--font-retro); font-size: 15px; color: var(--accent-blue);">Toast Notifications</span>
          <span style="font-family: var(--font-retro); font-size: 13px; color: var(--text-faint); margin-left: 8px;">Windows native popups for urgent emails, reminders, suggestions</span>
        </div>
      </div>
      <div style="border: 1px solid var(--border-subtle); padding: 12px 14px; display: flex; align-items: center; gap: 12px;">
        <span style="font-family: var(--font-pixel); font-size: 10px; color: var(--accent-purple);">+</span>
        <div>
          <span style="font-family: var(--font-retro); font-size: 15px; color: var(--accent-purple);">System Tray</span>
          <span style="font-family: var(--font-retro); font-size: 13px; color: var(--text-faint); margin-left: 8px;">Quick access, DND toggle, voice control from taskbar</span>
        </div>
      </div>
    </div>
  </section>

  <div class="hud-divider"></div>

  <section class="py-10 px-6 max-w-2xl mx-auto">
    <p class="section-label" style="color: var(--accent-purple);">MINIMUM SPECS</p>
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
      {specs.map(s => (
        <div style="border: 1px solid var(--border-subtle); padding: 14px;">
          <div style="font-family: var(--font-pixel); font-size: 8px; color: var(--text-faint); letter-spacing: 2px; margin-bottom: 6px;">{s.label}</div>
          <div style="font-family: var(--font-retro); font-size: 15px; color: var(--text-body);">{s.value}</div>
          {s.note && <div style={`font-family: var(--font-retro); font-size: 13px; color: ${s.noteColor}; margin-top: 3px;`}>{s.note}</div>}
        </div>
      ))}
    </div>
  </section>

  <div class="hud-divider"></div>

  <section class="py-10 px-6 max-w-2xl mx-auto">
    <p class="section-label" style="color: var(--accent-red);">OPTIONAL MODULES</p>
    <div class="flex flex-col gap-2">
      {modules.map(m => (
        <div class="flex justify-between items-center" style="border: 1px solid var(--border-subtle); padding: 10px 14px;">
          <div>
            <span style={`font-family: var(--font-retro); font-size: 15px; color: ${m.color}; letter-spacing: 1px;`}>{m.name}</span>
            <span style="font-family: var(--font-retro); font-size: 13px; color: var(--text-faint); margin-left: 8px;">{m.cmd}</span>
          </div>
          <span style="font-family: var(--font-retro); font-size: 13px; color: var(--text-faint);">{m.size}</span>
        </div>
      ))}
      <div class="flex justify-between items-center" style="border: 1px solid var(--border-gold); padding: 10px 14px; background: var(--bg-card);">
        <div>
          <span style="font-family: var(--font-retro); font-size: 15px; color: var(--accent-gold); letter-spacing: 1px;">Everything</span>
          <span style="font-family: var(--font-retro); font-size: 13px; color: var(--text-faint); margin-left: 8px;">pip install homie-ai[all]</span>
        </div>
        <span style="font-family: var(--font-pixel); font-size: 8px; color: var(--accent-gold);">FULL SUIT</span>
      </div>
    </div>
  </section>

  <div class="hud-divider"></div>

  <!-- PyPI badge -->
  <section class="py-8 px-6 text-center max-w-2xl mx-auto">
    <p style="font-family: var(--font-retro); font-size: 14px; color: var(--text-faint); letter-spacing: 1px;">
      Available on <a href="https://pypi.org/project/homie-ai/" style="color: var(--accent-blue); text-decoration: underline;">PyPI</a>
      &nbsp;•&nbsp;
      Source on <a href="https://github.com/MSG-88/Homie" style="color: var(--accent-blue); text-decoration: underline;">GitHub</a>
    </p>
    <p style="font-family: var(--font-pixel); font-size: 8px; color: var(--text-ghost); letter-spacing: 2px; margin-top: 8px;">
      LICENSE: MPL-2.0 • PYTHON 3.11+ • ZERO TELEMETRY
    </p>
  </section>
</BaseLayout>

<script>
  // Copy buttons
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const cmd = (btn as HTMLElement).dataset.cmd || '';
      navigator.clipboard.writeText(cmd);
      const el = btn as HTMLElement;
      el.textContent = 'COPIED ✓';
      setTimeout(() => { el.textContent = 'COPY'; }, 2000);
    });
  });

  // Platform detection
  function detectPlatform(): string {
    const uad = (navigator as any).userAgentData;
    if (uad?.platform) {
      const p = uad.platform.toLowerCase();
      if (p.includes('win')) return 'windows';
      if (p.includes('mac')) return 'macos';
      if (p.includes('linux')) return 'linux';
    }
    const p = navigator.platform.toLowerCase();
    if (p.includes('win')) return 'windows';
    if (p.includes('mac')) return 'macos';
    if (p.includes('linux')) return 'linux';
    return 'unknown';
  }

  const platform = detectPlatform();
  const cardMap: Record<string, string> = { windows: 'platform-windows', macos: 'platform-macos', linux: 'platform-linux' };
  const cardId = cardMap[platform];
  if (cardId) {
    const card = document.getElementById(cardId);
    if (card) {
      card.style.borderColor = 'rgba(241, 196, 15, 0.4)';
      card.style.borderWidth = '2px';
      const detect = card.querySelector('.platform-detect') as HTMLElement;
      if (detect) detect.style.visibility = 'visible';
      const name = card.querySelector('.platform-name') as HTMLElement;
      if (name) name.style.color = '#f1c40f';
    }
  }

  // Auto-scroll to Windows section if Windows detected
  if (platform === 'windows') {
    const section = document.getElementById('windows-installer');
    if (section) {
      section.style.borderLeft = '2px solid rgba(241, 196, 15, 0.3)';
    }
  }
</script>
